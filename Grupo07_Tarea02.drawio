        <mxCell id="vhkKfs0TKfNSvFn4A58v-1" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=none;strokeColor=default;dashed=1;" value="&lt;h3&gt;Clases principales&lt;/h3&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Socio&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Socio&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idSocio, nombre, apellido, email, teléfono, membresía&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: registrarse(), reservarCancha(), pagarServicio(), recibirNotificación()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Servicio&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Servicio&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idServicio, tipoServicio (alquiler cancha, entrenamiento, torneo), precio, duración&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: consultarDisponibilidad(), asignarCalendario()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Registro&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Registro&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idRegistro, fechaRegistro, socio, servicio&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: generarComprobante(), cancelarRegistro()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Calendario&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Calendario&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idCalendario, fecha, horaInicio, horaFin, cancha, estado&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: reservarHorario(), liberarHorario(), consultarDisponibilidad()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Administrador&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Administrador&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idAdmin, nombre, email, rol&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: gestionarSocios(), gestionarServicios(), generarReportes()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Pago&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Pago&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idPago, monto, fechaPago, métodoPago (tarjeta, efectivo, transferencia), estado&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: procesarPago(), validarPago(), emitirRecibo()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Notificacion&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Notificación&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idNotificación, mensaje, fechaEnvio, tipo (email, SMS, app)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: enviarNotificación(), programarRecordatorio()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="650" width="560" x="-800" y="30" as="geometry" />
        </mxCell>
        <mxCell id="vhkKfs0TKfNSvFn4A58v-2" parent="1" style="text;whiteSpace=wrap;html=1;strokeColor=default;dashed=1;" value="&lt;h2&gt; Relaciones entre clases&lt;/h2&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Socio ↔ Registro&lt;/strong&gt;: Un socio puede tener múltiples registros.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Registro ↔ Servicio&lt;/strong&gt;: Cada registro está asociado a un servicio.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Servicio ↔ Calendario&lt;/strong&gt;: Los servicios se asignan a horarios en el calendario.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Socio ↔ Pago&lt;/strong&gt;: Un socio realiza pagos por sus registros.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Administrador ↔ Socio/Servicio/Calendario&lt;/strong&gt;: El administrador gestiona todas las entidades.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Notificación ↔ Socio/Administrador&lt;/strong&gt;: Se envían notificaciones a socios y administradores.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="260" width="560" x="-200" y="30" as="geometry" />
        </mxCell>
        <UserObject label="from datetime import datetime&#xa;from typing import List&#xa;&#xa;&#xa;class Socio:&#xa;    def __init__(self, id_socio, nombre, apellido, email, telefono, membresia):&#xa;        self.id_socio = id_socio&#xa;        self.nombre = nombre&#xa;        self.apellido = apellido&#xa;        self.email = email&#xa;        self.telefono = telefono&#xa;        self.membresia = membresia&#xa;        self.registros: List[Registro] = []&#xa;        self.pagos: List[Pago] = []&#xa;&#xa;&#xa;    def registrarse(self):&#xa;        print(f&quot;Socio {self.nombre} registrado con éxito.&quot;)&#xa;&#xa;&#xa;    def reservar_cancha(self, servicio, calendario):&#xa;        registro = Registro(len(self.registros)+1, datetime.now(), self, servicio)&#xa;        calendario.reservar_horario()&#xa;        self.registros.append(registro)&#xa;        return registro&#xa;&#xa;&#xa;    def pagar_servicio(self, monto, metodo_pago):&#xa;        pago = Pago(len(self.pagos)+1, monto, datetime.now(), metodo_pago, &quot;Pendiente&quot;)&#xa;        pago.procesar_pago()&#xa;        self.pagos.append(pago)&#xa;&#xa;&#xa;    def recibir_notificacion(self, notificacion):&#xa;        print(f&quot;Notificación para {self.nombre}: {notificacion.mensaje}&quot;)&#xa;&#xa;&#xa;&#xa;&#xa;class Servicio:&#xa;    def __init__(self, id_servicio, tipo_servicio, precio, duracion):&#xa;        self.id_servicio = id_servicio&#xa;        self.tipo_servicio = tipo_servicio&#xa;        self.precio = precio&#xa;        self.duracion = duracion&#xa;&#xa;&#xa;    def consultar_disponibilidad(self):&#xa;        print(f&quot;Consultando disponibilidad del servicio {self.tipo_servicio}.&quot;)&#xa;&#xa;&#xa;    def asignar_calendario(self, calendario):&#xa;        calendario.reservar_horario()&#xa;&#xa;&#xa;&#xa;&#xa;class Registro:&#xa;    def __init__(self, id_registro, fecha_registro, socio, servicio):&#xa;        self.id_registro = id_registro&#xa;        self.fecha_registro = fecha_registro&#xa;        self.socio = socio&#xa;        self.servicio = servicio&#xa;&#xa;&#xa;    def generar_comprobante(self):&#xa;        return f&quot;Comprobante Registro {self.id_registro} - Socio: {self.socio.nombre}&quot;&#xa;&#xa;&#xa;    def cancelar_registro(self):&#xa;        print(f&quot;Registro {self.id_registro} cancelado.&quot;)&#xa;&#xa;&#xa;&#xa;&#xa;class Calendario:&#xa;    def __init__(self, id_calendario, fecha, hora_inicio, hora_fin, cancha, estado=&quot;Disponible&quot;):&#xa;        self.id_calendario = id_calendario&#xa;        self.fecha = fecha&#xa;        self.hora_inicio = hora_inicio&#xa;        self.hora_fin = hora_fin&#xa;        self.cancha = cancha&#xa;        self.estado = estado&#xa;&#xa;&#xa;    def reservar_horario(self):&#xa;        if self.estado == &quot;Disponible&quot;:&#xa;            self.estado = &quot;Reservado&quot;&#xa;            print(f&quot;Horario reservado en cancha {self.cancha}.&quot;)&#xa;        else:&#xa;            print(&quot;Horario no disponible.&quot;)&#xa;&#xa;&#xa;    def liberar_horario(self):&#xa;        self.estado = &quot;Disponible&quot;&#xa;        print(f&quot;Horario liberado en cancha {self.cancha}.&quot;)&#xa;&#xa;&#xa;    def consultar_disponibilidad(self):&#xa;        return self.estado&#xa;&#xa;&#xa;&#xa;&#xa;class Administrador:&#xa;    def __init__(self, id_admin, nombre, email, rol):&#xa;        self.id_admin = id_admin&#xa;        self.nombre = nombre&#xa;        self.email = email&#xa;        self.rol = rol&#xa;&#xa;&#xa;    def gestionar_socios(self, socios: List[Socio]):&#xa;        print(f&quot;Administrador {self.nombre} gestionando socios...&quot;)&#xa;&#xa;&#xa;    def gestionar_servicios(self, servicios: List[Servicio]):&#xa;        print(f&quot;Administrador {self.nombre} gestionando servicios...&quot;)&#xa;&#xa;&#xa;    def generar_reportes(self):&#xa;        print(&quot;Generando reportes del sistema...&quot;)&#xa;&#xa;&#xa;&#xa;&#xa;class Pago:&#xa;    def __init__(self, id_pago, monto, fecha_pago, metodo_pago, estado):&#xa;        self.id_pago = id_pago&#xa;        self.monto = monto&#xa;        self.fecha_pago = fecha_pago&#xa;        self.metodo_pago = metodo_pago&#xa;        self.estado = estado&#xa;&#xa;&#xa;    def procesar_pago(self):&#xa;        self.estado = &quot;Completado&quot;&#xa;        print(f&quot;Pago {self.id_pago} procesado con éxito.&quot;)&#xa;&#xa;&#xa;    def validar_pago(self):&#xa;        return self.estado == &quot;Completado&quot;&#xa;&#xa;&#xa;    def emitir_recibo(self):&#xa;        return f&quot;Recibo Pago {self.id_pago} - Monto: {self.monto}&quot;&#xa;&#xa;&#xa;&#xa;&#xa;class Notificacion:&#xa;    def __init__(self, id_notificacion, mensaje, fecha_envio, tipo):&#xa;        self.id_notificacion = id_notificacion&#xa;        self.mensaje = mensaje&#xa;        self.fecha_envio = fecha_envio&#xa;        self.tipo = tipo&#xa;&#xa;&#xa;    def enviar_notificacion(self, socio: Socio):&#xa;        socio.recibir_notificacion(self)&#xa;&#xa;&#xa;    def programar_recordatorio(self, fecha_recordatorio):&#xa;        print(f&quot;Recordatorio programado para {fecha_recordatorio}.&quot;)" link="from datetime import datetime&#xa;from typing import List&#xa;&#xa;&#xa;class Socio:&#xa;    def __init__(self, id_socio, nombre, apellido, email, telefono, membresia):&#xa;        self.id_socio = id_socio&#xa;        self.nombre = nombre&#xa;        self.apellido = apellido&#xa;        self.email = email&#xa;        self.telefono = telefono&#xa;        self.membresia = membresia&#xa;        self.registros: List[Registro] = []&#xa;        self.pagos: List[Pago] = []&#xa;&#xa;&#xa;    def registrarse(self):&#xa;        print(f&quot;Socio {self.nombre} registrado con éxito.&quot;)&#xa;&#xa;&#xa;    def reservar_cancha(self, servicio, calendario):&#xa;        registro = Registro(len(self.registros)+1, datetime.now(), self, servicio)&#xa;        calendario.reservar_horario()&#xa;        self.registros.append(registro)&#xa;        return registro&#xa;&#xa;&#xa;    def pagar_servicio(self, monto, metodo_pago):&#xa;        pago = Pago(len(self.pagos)+1, monto, datetime.now(), metodo_pago, &quot;Pendiente&quot;)&#xa;        pago.procesar_pago()&#xa;        self.pagos.append(pago)&#xa;&#xa;&#xa;    def recibir_notificacion(self, notificacion):&#xa;        print(f&quot;Notificación para {self.nombre}: {notificacion.mensaje}&quot;)&#xa;&#xa;&#xa;&#xa;&#xa;class Servicio:&#xa;    def __init__(self, id_servicio, tipo_servicio, precio, duracion):&#xa;        self.id_servicio = id_servicio&#xa;        self.tipo_servicio = tipo_servicio&#xa;        self.precio = precio&#xa;        self.duracion = duracion&#xa;&#xa;&#xa;    def consultar_disponibilidad(self):&#xa;        print(f&quot;Consultando disponibilidad del servicio {self.tipo_servicio}.&quot;)&#xa;&#xa;&#xa;    def asignar_calendario(self, calendario):&#xa;        calendario.reservar_horario()&#xa;&#xa;&#xa;&#xa;&#xa;class Registro:&#xa;    def __init__(self, id_registro, fecha_registro, socio, servicio):&#xa;        self.id_registro = id_registro&#xa;        self.fecha_registro = fecha_registro&#xa;        self.socio = socio&#xa;        self.servicio = servicio&#xa;&#xa;&#xa;    def generar_comprobante(self):&#xa;        return f&quot;Comprobante Registro {self.id_registro} - Socio: {self.socio.nombre}&quot;&#xa;&#xa;&#xa;    def cancelar_registro(self):&#xa;        print(f&quot;Registro {self.id_registro} cancelado.&quot;)&#xa;&#xa;&#xa;&#xa;&#xa;class Calendario:&#xa;    def __init__(self, id_calendario, fecha, hora_inicio, hora_fin, cancha, estado=&quot;Disponible&quot;):&#xa;        self.id_calendario = id_calendario&#xa;        self.fecha = fecha&#xa;        self.hora_inicio = hora_inicio&#xa;        self.hora_fin = hora_fin&#xa;        self.cancha = cancha&#xa;        self.estado = estado&#xa;&#xa;&#xa;    def reservar_horario(self):&#xa;        if self.estado == &quot;Disponible&quot;:&#xa;            self.estado = &quot;Reservado&quot;&#xa;            print(f&quot;Horario reservado en cancha {self.cancha}.&quot;)&#xa;        else:&#xa;            print(&quot;Horario no disponible.&quot;)&#xa;&#xa;&#xa;    def liberar_horario(self):&#xa;        self.estado = &quot;Disponible&quot;&#xa;        print(f&quot;Horario liberado en cancha {self.cancha}.&quot;)&#xa;&#xa;&#xa;    def consultar_disponibilidad(self):&#xa;        return self.estado&#xa;&#xa;&#xa;&#xa;&#xa;class Administrador:&#xa;    def __init__(self, id_admin, nombre, email, rol):&#xa;        self.id_admin = id_admin&#xa;        self.nombre = nombre&#xa;        self.email = email&#xa;        self.rol = rol&#xa;&#xa;&#xa;    def gestionar_socios(self, socios: List[Socio]):&#xa;        print(f&quot;Administrador {self.nombre} gestionando socios...&quot;)&#xa;&#xa;&#xa;    def gestionar_servicios(self, servicios: List[Servicio]):&#xa;        print(f&quot;Administrador {self.nombre} gestionando servicios...&quot;)&#xa;&#xa;&#xa;    def generar_reportes(self):&#xa;        print(&quot;Generando reportes del sistema...&quot;)&#xa;&#xa;&#xa;&#xa;&#xa;class Pago:&#xa;    def __init__(self, id_pago, monto, fecha_pago, metodo_pago, estado):&#xa;        self.id_pago = id_pago&#xa;        self.monto = monto&#xa;        self.fecha_pago = fecha_pago&#xa;        self.metodo_pago = metodo_pago&#xa;        self.estado = estado&#xa;&#xa;&#xa;    def procesar_pago(self):&#xa;        self.estado = &quot;Completado&quot;&#xa;        print(f&quot;Pago {self.id_pago} procesado con éxito.&quot;)&#xa;&#xa;&#xa;    def validar_pago(self):&#xa;        return self.estado == &quot;Completado&quot;&#xa;&#xa;&#xa;    def emitir_recibo(self):&#xa;        return f&quot;Recibo Pago {self.id_pago} - Monto: {self.monto}&quot;&#xa;&#xa;&#xa;&#xa;&#xa;class Notificacion:&#xa;    def __init__(self, id_notificacion, mensaje, fecha_envio, tipo):&#xa;        self.id_notificacion = id_notificacion&#xa;        self.mensaje = mensaje&#xa;        self.fecha_envio = fecha_envio&#xa;        self.tipo = tipo&#xa;&#xa;&#xa;    def enviar_notificacion(self, socio: Socio):&#xa;        socio.recibir_notificacion(self)&#xa;&#xa;&#xa;    def programar_recordatorio(self, fecha_recordatorio):&#xa;        print(f&quot;Recordatorio programado para {fecha_recordatorio}.&quot;)" id="vhkKfs0TKfNSvFn4A58v-3">

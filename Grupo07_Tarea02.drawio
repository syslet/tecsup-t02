        <mxCell id="vhkKfs0TKfNSvFn4A58v-1" parent="1" style="text;whiteSpace=wrap;html=1;fillColor=none;strokeColor=default;dashed=1;" value="&lt;h3&gt;Clases principales&lt;/h3&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Socio&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Socio&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idSocio, nombre, apellido, email, teléfono, membresía&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: registrarse(), reservarCancha(), pagarServicio(), recibirNotificación()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Servicio&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Servicio&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idServicio, tipoServicio (alquiler cancha, entrenamiento, torneo), precio, duración&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: consultarDisponibilidad(), asignarCalendario()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Registro&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Registro&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idRegistro, fechaRegistro, socio, servicio&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: generarComprobante(), cancelarRegistro()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Calendario&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Calendario&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idCalendario, fecha, horaInicio, horaFin, cancha, estado&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: reservarHorario(), liberarHorario(), consultarDisponibilidad()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Administrador&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Administrador&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idAdmin, nombre, email, rol&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: gestionarSocios(), gestionarServicios(), generarReportes()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Pago&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Pago&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idPago, monto, fechaPago, métodoPago (tarjeta, efectivo, transferencia), estado&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: procesarPago(), validarPago(), emitirRecibo()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;&lt;span role=&quot;button&quot; tabindex=&quot;0&quot; data-url=&quot;ca://s?q=Detalles_de_clase_Notificacion&quot; style=&quot;white-space: pre-wrap;&quot;&gt;Notificación&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Atributos: idNotificación, mensaje, fechaEnvio, tipo (email, SMS, app)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Métodos: enviarNotificación(), programarRecordatorio()&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="650" width="560" x="-800" y="30" as="geometry" />
        </mxCell>
        <mxCell id="vhkKfs0TKfNSvFn4A58v-2" parent="1" style="text;whiteSpace=wrap;html=1;strokeColor=default;dashed=1;" value="&lt;h2&gt; Relaciones entre clases&lt;/h2&gt;&lt;ul role=&quot;list&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Socio ↔ Registro&lt;/strong&gt;: Un socio puede tener múltiples registros.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Registro ↔ Servicio&lt;/strong&gt;: Cada registro está asociado a un servicio.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Servicio ↔ Calendario&lt;/strong&gt;: Los servicios se asignan a horarios en el calendario.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Socio ↔ Pago&lt;/strong&gt;: Un socio realiza pagos por sus registros.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Administrador ↔ Socio/Servicio/Calendario&lt;/strong&gt;: El administrador gestiona todas las entidades.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;&lt;strong style=&quot;white-space: pre-wrap;&quot;&gt;Notificación ↔ Socio/Administrador&lt;/strong&gt;: Se envían notificaciones a socios y administradores.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="260" width="560" x="-200" y="30" as="geometry" />
